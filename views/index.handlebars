<!-- Loading Screen -->
<div id="loading-screen">
    <div class="loading-content">
        <img src="/img/harperandlyre-logo.webp" alt="Harper and Lyre" class="loading-logo">
        <div class="loading-spinner"></div>
        <p class="loading-title">Loading Adventure...</p>
        <p class="loading-tip" id="loadingTip">Collect 144 Flazoozles scattered across the worlds!</p>
    </div>
</div>

<style>
    #loading-screen .loading-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    #loading-screen .loading-logo {
        width: 200px;
        height: auto;
        filter: drop-shadow(0 4px 12px rgba(255, 215, 63, 0.3));
        animation: logoFloat 3s ease-in-out infinite;
    }

    @keyframes logoFloat {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }

    #loading-screen .loading-title {
        font-family: 'Riffic', 'Bangers', Impact, cursive;
        font-size: 2rem;
        color: #ffffff;
        text-shadow: 2px 2px 0 #9B59B6;
        margin: 0;
    }

    #loading-screen .loading-tip {
        font-size: 1.1rem;
        color: #FFF8F0;
        text-align: center;
        max-width: 500px;
        padding: 0 1rem;
        margin: 0;
        opacity: 0.9;
        font-style: italic;
    }

    @media (max-width: 768px) {
        #loading-screen .loading-logo {
            width: 150px;
        }

        #loading-screen .loading-title {
            font-size: 1.5rem;
        }

        #loading-screen .loading-tip {
            font-size: 0.95rem;
        }
    }
</style>

<script>
    // Hide hero content before intro animation runs (avoids flash since loading screen covers page)
    (function () {
        var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) return;
        function hideHeroContent() {
            var heroSec = document.getElementById('home');
            if (!heroSec) return;
            var heroCt = heroSec.querySelector('.hero-content');
            var scrollInd = heroSec.querySelector('.scroll-indicator');
            var els = heroCt ? [
                heroCt.querySelector('.hero-title'),
                heroCt.querySelector('.hero-subtitle'),
                heroCt.querySelector('.hero-buttons'),
                heroCt.querySelector('.hero-features'),
                scrollInd
            ] : [];
            els.forEach(function(el) { if (el) el.style.opacity = '0'; });
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', hideHeroContent);
        } else {
            hideHeroContent();
        }
    }());

    // Gameplay video modal
    function initTrailerModal() {
        const modal = document.getElementById('gameplayModal');
        const iframe = document.getElementById('gameplayIframe');
        const openBtn = document.getElementById('jumpIntoFunBtn');
        const closeBtn = document.getElementById('gameplayModalClose');
        const overlay = document.getElementById('gameplayModalOverlay');

        if (!modal || !openBtn) return;

        function openModal() {
            iframe.src = iframe.dataset.src;
            modal.classList.add('is-open');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            modal.classList.remove('is-open');
            modal.setAttribute('aria-hidden', 'true');
            iframe.src = '';
            document.body.style.overflow = '';
        }

        openBtn.addEventListener('click', openModal);
        closeBtn.addEventListener('click', closeModal);
        overlay.addEventListener('click', closeModal);
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeModal();
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTrailerModal);
    } else {
        initTrailerModal();
    }

    // Loading tips from server
    const loadingTips = {{{loadingTipsJSON}}};

    const tipElement = document.getElementById('loadingTip');
    let lastTipIndex = 0;

    // Function to get a random tip that's different from the last one
    function getRandomTip() {
        let randomIndex;
        do {
            randomIndex = Math.floor(Math.random() * loadingTips.length);
        } while (randomIndex === lastTipIndex && loadingTips.length > 1);
        lastTipIndex = randomIndex;
        return loadingTips[randomIndex];
    }

    // Set initial random tip
    tipElement.textContent = getRandomTip();

    // Rotate tips every 2.5 seconds with random selection
    const tipInterval = setInterval(() => {
        if (tipElement) {
            tipElement.style.opacity = '0';
            setTimeout(() => {
                tipElement.textContent = getRandomTip();
                tipElement.style.opacity = '0.9';
            }, 300);
        }
    }, 2500);

    tipElement.style.transition = 'opacity 0.3s ease';

    // Remove loading screen when page is fully loaded
    window.addEventListener('load', () => {
        clearInterval(tipInterval);
        const loadingScreen = document.getElementById('loading-screen');
        if (loadingScreen) {
            loadingScreen.style.opacity = '0';
            loadingScreen.style.transition = 'opacity 0.5s ease';
            setTimeout(() => {
                loadingScreen.style.display = 'none';
            }, 500);
        }
    });

    // ─── HERO INTRO ANIMATION ───────────────────────────────────────────
    (function () {
        var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) return;

        var overlay   = document.getElementById('hero-intro-overlay');
        var phraseEl  = document.getElementById('hero-intro-phrase');
        var heroSec   = document.getElementById('home');
        var heroCt    = heroSec ? heroSec.querySelector('.hero-content') : null;
        var scrollInd = heroSec ? heroSec.querySelector('.scroll-indicator') : null;

        if (!overlay || !phraseEl || !heroCt) return;

        var PHRASES = [
            { text: 'THIS ALL NEW...',           tilt: 'hero-intro-phrase--tilt-left'  },
            { text: 'N64 STYLE GAME...',         tilt: ''                              },
            { text: "WE'VE BEEN WAITING FOR...", tilt: 'hero-intro-phrase--tilt-right' }
        ];

        var SLAM = 400, HOLD = 1200, FADE = 300, GAP = 300;
        var timers = [], done = false;

        function later(fn, ms) { var id = setTimeout(fn, ms); timers.push(id); return id; }
        function clearAll() { timers.forEach(clearTimeout); timers = []; }

        function getElements() {
            return [
                heroCt.querySelector('.hero-title'),
                heroCt.querySelector('.hero-subtitle'),
                heroCt.querySelector('.hero-buttons'),
                heroCt.querySelector('.hero-features'),
                scrollInd
            ].filter(Boolean);
        }

        function revealHero() {
            if (done) return;
            done = true;
            overlay.style.transition = 'opacity 0.35s ease';
            overlay.style.opacity = '0';
            later(function () { overlay.style.display = 'none'; }, 400);
            getElements().forEach(function (el, i) {
                later(function () {
                    el.style.transition = 'opacity 0.6s ease';
                    el.style.opacity = '1';
                }, i * 150);
            });
        }

        function showPhrase(index, next) {
            var data = PHRASES[index];
            phraseEl.textContent = data.text;
            phraseEl.className = 'hero-intro-phrase';
            if (data.tilt) phraseEl.classList.add(data.tilt);
            void phraseEl.offsetWidth; // force reflow so animation restarts
            phraseEl.classList.add('slam-in');

            later(function () {
                phraseEl.classList.remove('slam-in');
                void phraseEl.offsetWidth;
                phraseEl.classList.add('fade-out');
            }, SLAM + HOLD);

            later(function () {
                phraseEl.classList.remove('fade-out');
                phraseEl.style.opacity = '0';
                if (next) later(next, GAP);
            }, SLAM + HOLD + FADE);
        }

        function runSequence() {
            overlay.style.display = 'flex';
            overlay.style.opacity = '0';
            later(function () {
                overlay.style.transition = 'opacity 0.15s ease';
                overlay.style.opacity = '1';
            }, 0);
            later(function () {
                showPhrase(0, function () {
                    showPhrase(1, function () {
                        showPhrase(2, function () {
                            later(revealHero, GAP);
                        });
                    });
                });
            }, 150);
        }

        function onTabSkip(e) {
            if (e.key !== 'Tab' || done) return;
            clearAll();
            document.removeEventListener('keydown', onTabSkip);
            overlay.style.transition = 'none';
            overlay.style.opacity = '0';
            overlay.style.display = 'none';
            done = true;
            getElements().forEach(function (el) {
                el.style.transition = 'none';
                el.style.opacity = '1';
            });
        }

        document.addEventListener('keydown', onTabSkip);
        overlay.style.display = 'none';

        window.addEventListener('load', function () {
            later(runSequence, 700);
        }, { once: true });
    }());
    // ─── END HERO INTRO ANIMATION ──────────────────────────────────────────
</script>
